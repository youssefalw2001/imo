# ─── Fulfillment Server Config ───────────────────────────────────────────────

# Chrome/Chromium path (change based on your server OS)
CHROME_PATH=/usr/bin/chromium-browser

# Fulfillment API port
FULFILLMENT_PORT=3001

# ─── bKash Payment Config ────────────────────────────────────────────────────

# Your bKash merchant credentials (for auto-payment)
BKASH_PIN=YOUR_BKASH_PIN
BKASH_WALLET=01XXXXXXXXX

# ─── Admin Config ────────────────────────────────────────────────────────────

# Admin secret for protected endpoints
ADMIN_SECRET=change-this-to-a-random-string

# ─── Notifications ───────────────────────────────────────────────────────────

# Telegram bot token for order notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp webhook (optional)
WHATSAPP_WEBHOOK_URL=
